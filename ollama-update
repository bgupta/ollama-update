#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.6"

if ((BASH_VERSINFO[0] < 4)); then
  echo "Error: ollama-update requires bash 4.0+ (found ${BASH_VERSION})" >&2
  echo "On macOS: brew install bash" >&2
  exit 2
fi

# ollama-update - Check and update Ollama models, rebuild custom Modelfiles if needed
#
# Usage:
#   ollama-update                              # Check only (dry run)
#   ollama-update --update                     # Pull updates and rebuild Modelfiles
#   ollama-update --json                       # Output check results as JSON
#   ollama-update --quiet                      # Only show UPDATE/SKIP lines
#   ollama-update --update --defer-reload      # Update but skip VRAM reload
#   ollama-update --pin model1,model2          # Skip pinned models
#   ollama-update --config /path/to/config     # Use alternate config file
#   ollama-update --endpoint http://host:11434 # Use alternate Ollama endpoint
#   ollama-update --modelfile-dir /path/to/dir # Use alternate Modelfile directory
#   ollama-update --jobs N                     # Parallel check jobs (default: unlimited)

# Defaults
CONFIG_FILE="${HOME}/.config/ollama-update/config"
MODELFILE_DIR="${HOME}/.config/ollama-update/modelfiles"
OLLAMA_ENDPOINT="http://localhost:11434"
PINNED_MODELS=""
UPDATE=false
JSON=false
QUIET=false
DEFER_RELOAD=false
MAX_JOBS=0  # 0 = unlimited (all models at once)
SPAWN_DELAY=0

# CLI overrides — stored as parallel arrays to avoid eval
declare -a CLI_OVERRIDE_KEYS=()
declare -a CLI_OVERRIDE_VALS=()

die() { echo "Error: $1" >&2; exit 2; }

# Require a value argument for the given flag
require_arg() {
    local flag="$1" idx="$2" max="$3"
    [[ $idx -lt $max ]] || die "$flag requires a value"
}

# First pass: extract --config and collect all CLI overrides
args=("$@")
i=0
while [[ $i -lt ${#args[@]} ]]; do
    case "${args[$i]}" in
        --config)
            i=$((i + 1)); require_arg --config "$i" "${#args[@]}"
            CONFIG_FILE="${args[$i]}"
            ;;
        --modelfile-dir)
            i=$((i + 1)); require_arg --modelfile-dir "$i" "${#args[@]}"
            CLI_OVERRIDE_KEYS+=("MODELFILE_DIR"); CLI_OVERRIDE_VALS+=("${args[$i]}")
            ;;
        --endpoint)
            i=$((i + 1)); require_arg --endpoint "$i" "${#args[@]}"
            CLI_OVERRIDE_KEYS+=("OLLAMA_ENDPOINT"); CLI_OVERRIDE_VALS+=("${args[$i]}")
            ;;
        --pin)
            i=$((i + 1)); require_arg --pin "$i" "${#args[@]}"
            CLI_OVERRIDE_KEYS+=("PINNED_MODELS"); CLI_OVERRIDE_VALS+=("${args[$i]}")
            ;;
        --jobs)
            i=$((i + 1)); require_arg --jobs "$i" "${#args[@]}"
            [[ "${args[$i]}" =~ ^[0-9]+$ ]] || die "--jobs must be a positive integer"
            CLI_OVERRIDE_KEYS+=("MAX_JOBS"); CLI_OVERRIDE_VALS+=("${args[$i]}")
            ;;
        --update) CLI_OVERRIDE_KEYS+=("UPDATE"); CLI_OVERRIDE_VALS+=("true") ;;
        --json) CLI_OVERRIDE_KEYS+=("JSON"); CLI_OVERRIDE_VALS+=("true") ;;
        --quiet) CLI_OVERRIDE_KEYS+=("QUIET"); CLI_OVERRIDE_VALS+=("true") ;;
        --defer-reload) CLI_OVERRIDE_KEYS+=("DEFER_RELOAD"); CLI_OVERRIDE_VALS+=("true") ;;
        -v|--version)
            echo "ollama-update $VERSION"
            exit 0
            ;;
        -h|--help)
            cat <<'HELPEOF'
Usage: ollama-update [options]
Check for Ollama model updates by comparing local digests against the registry.

Actions:
  --update                Pull updates and rebuild custom Modelfiles
  --defer-reload          Skip reloading updated models in VRAM after update

Output:
  --json                  Output results as JSON
  --quiet                 Only show UPDATE and SKIP lines

Configuration:
  --config <path>         Config file (default: ~/.config/ollama-update/config)
  --modelfile-dir <path>  Custom Modelfile directory (default: ~/.config/ollama-update/modelfiles)
  --endpoint <url>        Ollama API endpoint (default: http://localhost:11434)
  --pin <m1,m2,...>       Comma-separated models to skip
  --jobs <N>              Parallel digest check jobs (default: unlimited)
  -v, --version           Print version and exit

Exit codes: 0 = all up to date, 1 = updates available, 2 = error

Examples:
  ollama-update                              Check for updates (dry run)
  ollama-update --update                     Pull updates and rebuild
  ollama-update --endpoint http://gpu:11434  Check a remote instance
  ollama-update --json --quiet               Machine-readable output
HELPEOF
            exit 0
            ;;
        *) die "unknown option: ${args[$i]}" ;;
    esac
    i=$((i + 1))
done

# Source config file (if it exists)
if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
fi

# Re-apply CLI overrides (CLI > config > defaults) — safe direct assignment
for ((k=0; k<${#CLI_OVERRIDE_KEYS[@]}; k++)); do
    case "${CLI_OVERRIDE_KEYS[$k]}" in
        MODELFILE_DIR)    MODELFILE_DIR="${CLI_OVERRIDE_VALS[$k]}" ;;
        OLLAMA_ENDPOINT)  OLLAMA_ENDPOINT="${CLI_OVERRIDE_VALS[$k]}" ;;
        PINNED_MODELS)    PINNED_MODELS="${CLI_OVERRIDE_VALS[$k]}" ;;
        MAX_JOBS)         MAX_JOBS="${CLI_OVERRIDE_VALS[$k]}" ;;
        UPDATE)           UPDATE="${CLI_OVERRIDE_VALS[$k]}" ;;
        JSON)             JSON="${CLI_OVERRIDE_VALS[$k]}" ;;
        QUIET)            QUIET="${CLI_OVERRIDE_VALS[$k]}" ;;
        DEFER_RELOAD)     DEFER_RELOAD="${CLI_OVERRIDE_VALS[$k]}" ;;
    esac
done

# Check required dependencies
for cmd in curl jq ollama; do
    command -v "$cmd" >/dev/null 2>&1 || die "$cmd is required but not found in PATH"
done

# Export OLLAMA_HOST so ollama pull/create honor --endpoint
export OLLAMA_HOST="$OLLAMA_ENDPOINT"

REGISTRY="https://registry.ollama.ai/v2/library"
UPDATED_BASES=()
REBUILT_CUSTOMS=()
RESULTS=()

# Temp dir for parallel check results
TMPDIR_CHECK=$(mktemp -d)
trap 'rm -rf "$TMPDIR_CHECK"' EXIT

# Snapshot currently loaded models: name -> expires_at (ISO timestamp)
declare -A LOADED_MODELS
while IFS=$'\t' read -r lm_name lm_expires; do
    LOADED_MODELS["$lm_name"]="$lm_expires"
done < <(curl -s "${OLLAMA_ENDPOINT}/api/ps" 2>/dev/null \
    | jq -r '.models[]? | "\(.name)\t\(.expires_at // "")"' 2>/dev/null)

# Get local model weight blob digest via API
# Returns: digest string, empty string (no modelfile), or "ERROR:<message>" on API error
get_local_digest() {
    local model="$1"
    local resp
    resp=$(curl -s "${OLLAMA_ENDPOINT}/api/show" -d "{\"name\":\"$model\"}" 2>/dev/null) || { echo "ERROR:api_request_failed"; return; }
    # Check for error field in response (e.g. {"error":"internal failure"})
    local err
    err=$(echo "$resp" | jq -r '.error // empty' 2>/dev/null)
    if [[ -n "$err" ]]; then
        echo "ERROR:${err}"
        return
    fi
    echo "$resp" | jq -r '(.modelfile // "" | capture("sha256-(?<h>[a-f0-9]+)"))? // empty | "sha256:" + .h' 2>/dev/null
}

# Get remote model weight blob digest from registry manifest
# Returns: digest string, empty string (not in registry), or "ERROR:<message>" on API error
get_remote_digest() {
    local lib="$1" tag="$2"
    local url
    if [[ "$lib" == *"/"* ]]; then
        url="https://registry.ollama.ai/v2/${lib}/manifests/${tag}"
    else
        url="${REGISTRY}/${lib}/manifests/${tag}"
    fi
    local resp
    resp=$(curl -s --max-time 10 \
        -H "Accept: application/vnd.docker.distribution.manifest.v2+json" \
        "$url" 2>/dev/null) || { echo "ERROR:registry_request_failed"; return; }
    # Check for Docker registry error response (e.g. {"errors":[...]})
    local has_errors
    has_errors=$(echo "$resp" | jq -r '.errors // empty | if length > 0 then "yes" else empty end' 2>/dev/null)
    if [[ -n "$has_errors" ]]; then
        local errmsg
        errmsg=$(echo "$resp" | jq -r '.errors[0].message // "unknown registry error"' 2>/dev/null)
        echo "ERROR:${errmsg}"
        return
    fi
    # Check for non-JSON response (e.g. rate-limit HTML pages)
    local has_layers
    has_layers=$(echo "$resp" | jq -e '.layers' >/dev/null 2>&1 && echo "yes" || true)
    if [[ -z "$has_layers" ]]; then
        # Response is not a valid manifest (could be HTML or malformed JSON)
        local snippet="${resp:0:80}"
        echo "ERROR:invalid_manifest_response (${snippet})"
        return
    fi
    echo "$resp" | jq -r '[.layers[]? | select(.mediaType | contains("model"))] | first | .digest // empty' 2>/dev/null
}

# Parse model name into library and tag
parse_model() {
    local model="$1"
    local lib="${model%%:*}"
    local tag="${model##*:}"
    [[ "$tag" == "$lib" ]] && tag="latest"
    echo "$lib" "$tag"
}

# Convert ISO 8601 timestamp to epoch seconds (portable: GNU and macOS)
portable_epoch() {
    local ts="$1"
    [[ -z "$ts" ]] && echo 0 && return
    # Try GNU date first
    local epoch
    epoch=$(date -d "$ts" +%s 2>/dev/null) && { echo "$epoch"; return; }
    # macOS: strip fractional seconds and colon in timezone for date -jf
    local clean="${ts%%.*}"           # remove .nnnnnnnnn fractional part
    local tz_sign="" tz_val=""
    if [[ "$ts" =~ [+-][0-9]{2}:[0-9]{2}$ ]]; then
        tz_sign="${ts: -6:1}"         # + or -
        tz_val="${ts: -5}"            # HH:MM
        tz_val="${tz_val/:/}"         # HHMM
        clean="${clean}${tz_sign}${tz_val}"
    elif [[ "$ts" == *"Z"* || "$ts" == *"z"* ]]; then
        clean="${clean}+0000"
    fi
    epoch=$(date -jf "%Y-%m-%dT%H:%M:%S%z" "$clean" +%s 2>/dev/null) && { echo "$epoch"; return; }
    echo 0
}

# Build map of custom Modelfiles: custom_name -> base_model
declare -A CUSTOM_MODELS
if [[ -d "$MODELFILE_DIR" ]]; then
    for mf in "$MODELFILE_DIR"/Modelfile-*; do
        [[ -f "$mf" ]] || continue
        custom_name="${mf##*/Modelfile-}"
        base_model=$(grep "^FROM " "$mf" | head -1 | awk '{print $2}')
        if [[ -n "$base_model" ]]; then
            CUSTOM_MODELS["$custom_name"]="$base_model"
        fi
    done
fi

# Get model list via API (respects --endpoint for remote checks)
get_model_list() {
    curl -sf --max-time 5 "${OLLAMA_ENDPOINT}/api/tags" 2>/dev/null \
        | jq -r '.models[]?.name' 2>/dev/null | sort -u
}

# Verify endpoint is reachable before proceeding
if ! curl -sf --max-time 5 "${OLLAMA_ENDPOINT}/api/tags" >/dev/null 2>&1; then
    die "cannot reach Ollama at ${OLLAMA_ENDPOINT}"
fi

model_count=$(get_model_list | wc -l)
if ! $QUIET && ! $JSON; then
    jobs_display="unlimited"; [[ $MAX_JOBS -gt 0 ]] && jobs_display="$MAX_JOBS"
    echo "Checking ${model_count} models against registry (${jobs_display} parallel)..."
    echo ""
fi

# ── Phase 1: Categorize models (synchronous, instant) ──
declare -a CHECK_MODELS=()
declare -a CHECK_MODES=()
idx=0

while IFS= read -r model; do
    [[ -z "$model" ]] && continue
    read -r lib tag <<< "$(parse_model "$model")"

    # Check if model is pinned
    if [[ -n "$PINNED_MODELS" ]]; then
        IFS=',' read -ra _pins <<< "$PINNED_MODELS"
        _pinned=false
        for _p in "${_pins[@]}"; do
            if [[ "$model" == "$_p" || "$lib" == "$_p" ]]; then
                _pinned=true
                break
            fi
        done
        if $_pinned; then
            echo "PIN|$model|pinned" > "${TMPDIR_CHECK}/${idx}"
            CHECK_MODELS[$idx]="$model"
            CHECK_MODES[$idx]="done"
            idx=$((idx + 1))
            continue
        fi
    fi

    # Custom Modelfile-based model — resolve base before spawning worker
    custom_key=""
    if [[ -n "${CUSTOM_MODELS[$model]+x}" ]]; then
        custom_key="$model"
    elif [[ "$tag" == "latest" && -n "${CUSTOM_MODELS[$lib]+x}" ]]; then
        custom_key="$lib"
    fi
    if [[ -n "$custom_key" ]]; then
        base="${CUSTOM_MODELS[$custom_key]}"
        read -r base_lib base_tag <<< "$(parse_model "$base")"
        CHECK_MODELS[$idx]="$model"
        CHECK_MODES[$idx]="custom:${base_lib}:${base_tag}:${base}"
        idx=$((idx + 1))
        continue
    fi

    # Standard model — needs digest check
    CHECK_MODELS[$idx]="$model"
    CHECK_MODES[$idx]="standard"
    idx=$((idx + 1))
done < <(get_model_list)

total=$idx

# ── Phase 2: Parallel digest checks ──
# Worker function — runs in background, writes result to temp file
check_model_worker() {
    local widx="$1" wmodel="$2" wmode="$3"
    local result=""

    if [[ "$wmode" == custom:* ]]; then
        IFS=: read -r _ base_lib base_tag base <<< "$wmode"
        local base_local base_remote
        base_local=$(get_local_digest "$base")
        if [[ "$base_local" == ERROR:* ]]; then
            result="ERROR|$wmodel|local_api_error (${base_local#ERROR:})"
        else
            base_remote=$(get_remote_digest "$base_lib" "$base_tag")
            if [[ "$base_remote" == ERROR:* ]]; then
                result="ERROR|$wmodel|registry_error (${base_remote#ERROR:})"
            elif [[ -z "$base_remote" ]]; then
                result="SKIP|$wmodel|custom_base_not_in_registry"
            elif [[ -n "$base_local" && "$base_local" != "$base_remote" ]]; then
                result="UPDATE|$wmodel|custom"
            else
                local custom_digest
                custom_digest=$(get_local_digest "$wmodel")
                if [[ "$custom_digest" == ERROR:* ]]; then
                    result="ERROR|$wmodel|local_api_error (${custom_digest#ERROR:})"
                elif [[ "$custom_digest" != "$base_local" ]]; then
                    result="UPDATE|$wmodel|custom"
                else
                    result="OK|$wmodel|custom"
                fi
            fi
        fi
    else
        local local_digest remote_digest wlib wtag
        read -r wlib wtag <<< "$(parse_model "$wmodel")"
        local_digest=$(get_local_digest "$wmodel")
        if [[ "$local_digest" == ERROR:* ]]; then
            result="ERROR|$wmodel|local_api_error (${local_digest#ERROR:})"
        elif [[ -z "$local_digest" ]]; then
            result="SKIP|$wmodel|no_modelfile"
        else
            remote_digest=$(get_remote_digest "$wlib" "$wtag")
            if [[ "$remote_digest" == ERROR:* ]]; then
                result="ERROR|$wmodel|registry_error (${remote_digest#ERROR:})"
            elif [[ -z "$remote_digest" ]]; then
                result="SKIP|$wmodel|not_in_registry"
            elif [[ "$local_digest" == "$remote_digest" ]]; then
                result="OK|$wmodel|"
            else
                result="UPDATE|$wmodel|"
            fi
        fi
    fi
    echo "$result" > "${TMPDIR_CHECK}/${widx}"
}

# Print a single result line and append to RESULTS[]
print_result() {
    local j="$1"
    local result_file="${TMPDIR_CHECK}/${j}"
    [[ -f "$result_file" ]] || return 1
    local result
    result=$(< "$result_file")
    RESULTS+=("$result")

    $JSON && return 0

    local status model reason
    IFS='|' read -r status model reason <<< "$result"

    # Quiet mode: only show UPDATE and SKIP
    if $QUIET; then
        case "$status" in
            OK|PIN) return 0 ;;
        esac
    fi

    case "$status" in
        PIN)    echo "PIN   $model" ;;
        ERROR)  echo "ERROR $model${reason:+ ($reason)}" ;;
        SKIP)
            case "$reason" in
                custom_base_not_in_registry)
                    if [[ "${CHECK_MODES[$j]}" == custom:* ]]; then
                        IFS=: read -r _ _ _ base <<< "${CHECK_MODES[$j]}"
                        echo "SKIP  $model (custom: base $base not in registry)"
                    else
                        echo "SKIP  $model ($reason)"
                    fi
                    ;;
                no_modelfile) echo "SKIP  $model (unknown, no modelfile)" ;;
                not_in_registry) echo "SKIP  $model (not in registry)" ;;
                *) echo "SKIP  $model${reason:+ ($reason)}" ;;
            esac
            ;;
        OK)
            if [[ "$reason" == "custom" ]]; then
                if [[ "${CHECK_MODES[$j]}" == custom:* ]]; then
                    IFS=: read -r _ _ _ base <<< "${CHECK_MODES[$j]}"
                    echo "OK    $model (custom: base $base up to date)"
                else
                    echo "OK    $model (custom)"
                fi
            else
                echo "OK    $model"
            fi
            ;;
        UPDATE)
            if [[ "$reason" == "custom" ]]; then
                if [[ "${CHECK_MODES[$j]}" == custom:* ]]; then
                    IFS=: read -r _ _ _ base <<< "${CHECK_MODES[$j]}"
                    echo "UPDATE $model (custom: base $base has update)"
                else
                    echo "UPDATE $model (custom)"
                fi
            else
                echo "UPDATE $model"
            fi
            ;;
    esac
}

# Export functions and vars needed by subshells
export OLLAMA_ENDPOINT REGISTRY TMPDIR_CHECK
export -f check_model_worker get_local_digest get_remote_digest parse_model portable_epoch

# ── Phase 2.5: Launch parallel workers, collect results in order ──
printed_count=0

# Background: launch workers + throttle
(
    bg_pids=()
    for ((j=0; j<total; j++)); do
        [[ "${CHECK_MODES[$j]}" == "done" ]] && continue
        check_model_worker "$j" "${CHECK_MODELS[$j]}" "${CHECK_MODES[$j]}" &
        bg_pids+=($!)
        [[ "$SPAWN_DELAY" != "0" ]] && sleep "$SPAWN_DELAY"
        if [[ $MAX_JOBS -gt 0 && ${#bg_pids[@]} -ge $MAX_JOBS ]]; then
            # Wait for at least one job to finish (portable, no wait -n)
            while true; do
                for k in "${!bg_pids[@]}"; do
                    if ! kill -0 "${bg_pids[$k]}" 2>/dev/null; then
                        wait "${bg_pids[$k]}" 2>/dev/null || true
                        unset 'bg_pids[k]'
                        break 2
                    fi
                done
                sleep 0.05
            done
        fi
    done
    wait
    touch "${TMPDIR_CHECK}/ALL_DONE"
) &
launcher_pid=$!

# Update trap to clean up background launcher
trap 'kill "$launcher_pid" 2>/dev/null || true; rm -rf "$TMPDIR_CHECK"' EXIT

# Wait for all workers to finish
while [[ ! -f "${TMPDIR_CHECK}/ALL_DONE" ]]; do
    sleep 0.05
done

# Print all results in deterministic order (sorted by model name via get_model_list)
for ((j=0; j<total; j++)); do
    if [[ -f "${TMPDIR_CHECK}/${j}" ]]; then
        print_result "$j"
        printed_count=$((printed_count + 1))
    fi
done

# Detect workers that crashed without producing a result file
if [[ $printed_count -lt $total ]]; then
    missing=$((total - printed_count))
    for ((j=0; j<total; j++)); do
        [[ -f "${TMPDIR_CHECK}/${j}" ]] && continue
        model="${CHECK_MODELS[$j]}"
        RESULTS+=("ERROR|${model}|registry unreachable")
    done
    if ! $JSON && ! $QUIET; then
        echo "WARN  ${missing} model(s) failed to check (registry unreachable?)"
    fi
fi

# ── Phase 4: Sequential updates ──
if $UPDATE; then
    for r in "${RESULTS[@]}"; do
        IFS='|' read -r status model reason <<< "$r"
        [[ "$status" == "UPDATE" ]] || continue

        # Find the CHECK_MODES index for this model to get custom base info
        for ((j=0; j<total; j++)); do
            [[ "${CHECK_MODELS[$j]}" == "$model" ]] && break
        done

        if [[ "$reason" == "custom" && "${CHECK_MODES[$j]}" == custom:* ]]; then
            IFS=: read -r _ _ _ base <<< "${CHECK_MODES[$j]}"
            echo "  -> Pulling base $base..."
            ollama pull "$base"
            UPDATED_BASES+=("$base")
        else
            echo "  -> Pulling $model..."
            ollama pull "$model"
            UPDATED_BASES+=("$model")
        fi
    done
fi

# Rebuild custom Modelfiles if their base was updated
if $UPDATE && [[ ${#CUSTOM_MODELS[@]} -gt 0 ]]; then
    echo ""
    echo "Checking custom Modelfiles..."
    for custom_name in "${!CUSTOM_MODELS[@]}"; do
        base="${CUSTOM_MODELS[$custom_name]}"
        needs_rebuild=false

        # Check if the base model was just updated
        for updated in "${UPDATED_BASES[@]}"; do
            if [[ "$updated" == "$base" ]]; then
                needs_rebuild=true
                break
            fi
        done

        # Even if base wasn't in our update list, check if the custom model's
        # FROM blob matches the current base model's blob
        if ! $needs_rebuild; then
            custom_blob=$(get_local_digest "$custom_name" 2>/dev/null)
            base_blob=$(get_local_digest "$base" 2>/dev/null)
            if [[ -n "$custom_blob" && -n "$base_blob" && "$custom_blob" != "$base_blob" ]]; then
                needs_rebuild=true
                echo "  $custom_name: base model $base has newer weights than custom model"
            fi
        fi

        if $needs_rebuild; then
            mf="$MODELFILE_DIR/Modelfile-${custom_name}"
            if [[ -f "$mf" ]]; then
                echo "  -> Rebuilding $custom_name from $mf..."
                ollama create "$custom_name" -f "$mf"
                REBUILT_CUSTOMS+=("$custom_name")
            else
                echo "  WARN: No Modelfile found at $mf for $custom_name"
            fi
        else
            echo "  OK  $custom_name (base $base unchanged)"
        fi
    done
fi

# Reload updated models that were loaded in VRAM
if $UPDATE && ! $DEFER_RELOAD && [[ ${#LOADED_MODELS[@]} -gt 0 ]]; then
    reload_needed=false
    for lm_name in "${!LOADED_MODELS[@]}"; do
        was_updated=false
        for updated in "${UPDATED_BASES[@]}"; do
            if [[ "$updated" == "$lm_name" || "${updated}:latest" == "$lm_name" ]]; then
                was_updated=true; break
            fi
        done
        if ! $was_updated; then
            for rebuilt in "${REBUILT_CUSTOMS[@]}"; do
                if [[ "$rebuilt" == "$lm_name" || "${rebuilt}:latest" == "$lm_name" ]]; then
                    was_updated=true; break
                fi
            done
        fi
        if $was_updated; then
            if ! $reload_needed; then
                echo ""
                echo "Reloading updated models in VRAM..."
                reload_needed=true
            fi
            expires_at="${LOADED_MODELS[$lm_name]}"
            exp_epoch=$(portable_epoch "$expires_at")
            now_epoch=$(date +%s)
            keep_alive=$(( exp_epoch - now_epoch ))
            [[ $keep_alive -lt 1 ]] && keep_alive=-1
            echo "  -> Unloading $lm_name..."
            unload_resp=$(curl -s "${OLLAMA_ENDPOINT}/api/generate" -d "{\"model\":\"$lm_name\",\"keep_alive\":0}" 2>/dev/null)
            if echo "$unload_resp" | jq -e '.error' >/dev/null 2>&1; then
                echo "  WARN  $lm_name unload failed: $(echo "$unload_resp" | jq -r '.error')"
                continue
            fi
            echo "  -> Reloading $lm_name (keep_alive: ${keep_alive}s)..."
            reload_resp=$(curl -s "${OLLAMA_ENDPOINT}/api/generate" -d "{\"model\":\"$lm_name\",\"keep_alive\":$keep_alive}" 2>/dev/null)
            if echo "$reload_resp" | jq -e '.error' >/dev/null 2>&1; then
                echo "  WARN  $lm_name reload failed: $(echo "$reload_resp" | jq -r '.error')"
            else
                echo "  OK  $lm_name reloaded"
            fi
        fi
    done
elif $UPDATE && $DEFER_RELOAD && [[ ${#LOADED_MODELS[@]} -gt 0 ]]; then
    echo ""
    echo "Reload deferred — updated models will cold-load on next use."
fi

# ── Summary ──
count_ok=0; count_update=0; count_skip=0; count_pin=0; count_error=0
for r in "${RESULTS[@]}"; do
    IFS='|' read -r s _ _ <<< "$r"
    case "$s" in
        OK)     count_ok=$((count_ok + 1)) ;;
        UPDATE) count_update=$((count_update + 1)) ;;
        PIN)    count_pin=$((count_pin + 1)) ;;
        SKIP)   count_skip=$((count_skip + 1)) ;;
        ERROR)  count_error=$((count_error + 1)) ;;
    esac
done

elapsed="${SECONDS}.0"

# Exit code: 0=all ok, 1=updates available, 2=check failures (SKIPs are expected, not errors)
exit_code=0
if [[ $count_error -gt 0 ]]; then
    exit_code=2
elif [[ $count_update -gt 0 ]]; then
    # --update mode: exit 0 after successful pulls (updates were applied)
    if $UPDATE; then
        exit_code=0
    else
        exit_code=1
    fi
fi

# JSON output
if $JSON; then
    echo "{"
    echo "  \"results\": ["
    for i in "${!RESULTS[@]}"; do
        IFS='|' read -r status model reason <<< "${RESULTS[$i]}"
        comma=","
        [[ $i -eq $((${#RESULTS[@]}-1)) ]] && comma=""
        echo "    {\"status\": \"$status\", \"model\": \"$model\"${reason:+, \"reason\": \"$reason\"}}$comma"
    done
    echo "  ],"
    echo "  \"summary\": {"
    echo "    \"total\": ${#RESULTS[@]},"
    echo "    \"ok\": $count_ok,"
    echo "    \"update\": $count_update,"
    echo "    \"skip\": $count_skip,"
    echo "    \"pin\": $count_pin,"
    echo "    \"error\": $count_error,"
    echo "    \"elapsed_s\": $elapsed"
    echo "  }"
    echo "}"
else
    echo ""
    echo "Done: $count_ok ok, $count_update update, $count_skip skip, $count_pin pin, $count_error error (${elapsed}s)"
    if [[ $count_update -gt 0 ]] && ! $UPDATE; then
        echo "Run with --update to pull updates and rebuild custom Modelfiles."
    fi
fi

exit "$exit_code"
